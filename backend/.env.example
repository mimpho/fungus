# ── Base de datos ────────────────────────────────────────────────────────────
# Dev local (docker compose up -d):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fungus
# Producción — Supabase: Settings → Database → Connection string (Transaction mode):
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.xxxx.supabase.co:5432/postgres

# ── Seguridad ────────────────────────────────────────────────────────────────
# openssl rand -hex 32
SECRET_KEY=cambia-esto-en-produccion

# ── APIs meteorológicas (P1 - opcionales, fallback a Open-Meteo si no están) ─
METEOCAT_API_KEY=
AEMET_API_KEY=

# ── Entorno ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO

# ── CORS (dominios permitidos, separados por coma) ───────────────────────────
CORS_ORIGINS=http://localhost:5173,https://fungus.vercel.app

# ── Ingesta ──────────────────────────────────────────────────────────────────
INGEST_CRON_HOUR=5               # hora UTC del cron diario (05:00 UTC = 07:00 Madrid)
INGEST_MAX_CONCURRENCY=6         # llamadas paralelas a APIs externas
